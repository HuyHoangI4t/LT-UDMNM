        "/api/admission-majors": {
            "get": {
                "tags": [
                    "Admission Majors"
                ],
                "summary": "Danh sach nganh tuyen sinh",
                "operationId": "b633927af6d0e79d22609e818ed013d9",
                "responses": {
                    "200": {
                        "description": "Danh sach nganh"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Admission Majors"
                ],
                "summary": "Tao nganh tuyen sinh",
                "operationId": "3c24696fa2318c30adaa32118c0b4a03",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "major_name"
                                ],
                                "properties": {
                                    "year": {
                                        "type": "integer",
                                        "example": 2026
                                    },
                                    "major_name": {
                                        "type": "string",
                                        "example": "Cong nghe thong tin"
                                    },
                                    "major_code": {
                                        "type": "string",
                                        "example": "7480201"
                                    },
                                    "subject_groups": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "A00",
                                            "A01"
                                        ]
                                    },
                                    "quota": {
                                        "type": "integer",
                                        "example": 120
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Tao thanh cong"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
