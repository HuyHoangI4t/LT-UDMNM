        "/api/chat-logs": {
            "get": {
                "tags": [
                    "Quản lý Dashboard"
                ],
                "summary": "Lấy danh sách lịch sử hội thoại (dành cho Dashboard)",
                "operationId": "10dad1da8d7d77eadeb7b2777b291499",
                "responses": {
                    "200": {
                        "description": "Thành công",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "description": "Đối tượng phân trang của Laravel",
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "example": 1
