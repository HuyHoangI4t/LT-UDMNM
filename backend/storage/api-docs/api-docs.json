                                                "first_page_url": {
                                                    "type": "string"
                                                },
                                                "last_page": {
                                                    "type": "integer",
                                                    "example": 5
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "example": 45
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/chat-logs/{id}": {
            "get": {
                "tags": [
                    "Quản lý Dashboard"
